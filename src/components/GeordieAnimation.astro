---
// Geordie animation stage.
//
// Composition model:
//   - <BaseLayer /> is the static foundation (z-index 0, never animated).
//   - Animated layers go in the default <slot/> and stack above it.
//   - The GSAP master timeline below is the single entry point for all motion;
//     add per-layer tweens to it as layers are introduced.
import BaseLayer from './BaseLayer.astro';

interface Props {
  /** Whether the timeline should start playing on load. */
  autoplay?: boolean;
}

const { autoplay = true } = Astro.props;
---

<div class="geordie-stage" data-geordie-stage data-autoplay={String(autoplay)}>
  <BaseLayer />
  <div class="geordie-layers">
    <slot />
  </div>
</div>

<style>
  .geordie-stage {
    position: relative;
    width: 100%;
    /* Preserve the landscape PNG's native 3466 x 1816 aspect ratio. */
    aspect-ratio: 3466 / 1816;
    overflow: hidden;
  }
  .geordie-layers {
    position: absolute;
    inset: 0;
    z-index: 1;
  }
</style>

<script>
  import { gsap } from 'gsap';

  function initStage(stage: HTMLElement) {
    const autoplay = stage.dataset.autoplay !== 'false';

    // Respect users who prefer reduced motion.
    const prefersReduced = window.matchMedia(
      '(prefers-reduced-motion: reduce)'
    ).matches;

    // Layer hooks.
    const flameRig = stage.querySelector('.flame-rig');
    const radiance = stage.querySelector('[data-radiance-bloom]');
    const fogLeft = stage.querySelector('[data-fog-left]');
    const fogRight = stage.querySelector('[data-fog-right]');

    // Resting state: flame dim, radiance hidden, fog in place.
    gsap.set(flameRig, { transformOrigin: '50% 100%', scale: 0.78, opacity: 0.4 });
    gsap.set(radiance, {
      xPercent: -50,
      yPercent: -50,
      transformOrigin: '50% 50%',
      scale: 0.3,
      opacity: 0,
    });

    // Master timeline — every animated layer hangs off this.
    const tl = gsap.timeline({
      paused: !autoplay,
      defaults: { ease: 'power2.inOut' },
    });
    (stage as any)._geordieTimeline = tl;

    // Reduced motion: skip the show, settle straight to the revealed end state.
    if (prefersReduced) {
      gsap.set(flameRig, { scale: 1, opacity: 1 });
      gsap.set(radiance, { scale: 1, opacity: 1 });
      gsap.set([fogLeft, fogRight], { opacity: 0 });
      return tl;
    }

    // 1. Hold ~3s — fog drifts (CSS), flame stays dim.
    tl.to({}, { duration: 3 });

    // 2. Flame grows prominent and bright (capped at base size so it fits).
    tl.to(
      flameRig,
      { scale: 1, opacity: 1, duration: 1.6, ease: 'power2.out' },
      3
    );

    // 3. Radiance ignites in a pulsating burst (rapid throbs that ramp up),
    //    then settles to a steady glow (the CSS pulse takes over from there);
    //    the fog disperses to each side.
    const burst = 4.4;
    const ignite = gsap.timeline();
    ignite
      .to(radiance, { opacity: 0.7, scale: 0.72, duration: 0.16, ease: 'power2.out' })
      .to(radiance, { opacity: 0.4, scale: 0.58, duration: 0.14, ease: 'power2.in' })
      .to(radiance, { opacity: 0.95, scale: 0.94, duration: 0.15, ease: 'power2.out' })
      .to(radiance, { opacity: 0.6, scale: 0.8, duration: 0.14, ease: 'power2.in' })
      .to(radiance, { opacity: 1, scale: 1.08, duration: 0.14, ease: 'power2.out' })
      .to(radiance, { opacity: 0.85, scale: 0.97, duration: 0.13, ease: 'power2.in' })
      .to(radiance, { opacity: 1, scale: 1, duration: 0.55, ease: 'power1.inOut' });
    tl.add(ignite, burst);

    tl.to(
      fogLeft,
      { xPercent: -70, opacity: 0, duration: 2.4, ease: 'power2.in' },
      burst + 0.3
    );
    tl.to(
      fogRight,
      { xPercent: 70, opacity: 0, duration: 2.4, ease: 'power2.in' },
      burst + 0.3
    );

    return tl;
  }

  function boot() {
    document
      .querySelectorAll<HTMLElement>('[data-geordie-stage]')
      .forEach(initStage);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else {
    boot();
  }
</script>
